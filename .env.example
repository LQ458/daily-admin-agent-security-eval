# Default provider used by README examples.
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional OpenAI-compatible providers. Uncomment and fill only what you use.
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=your-openai-model-id

# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=provider/model-id

# SiliconFlow is useful for testing domestic model families such as GLM, Qwen,
# DeepSeek, Kimi, Hunyuan, MiniMax, and Step through one OpenAI-compatible API.
# SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_MODEL=Pro/zai-org/GLM-4.7

# TOGETHER_API_KEY=your-together-key-here
# TOGETHER_BASE_URL=https://api.together.xyz/v1
# TOGETHER_MODEL=your-together-model-id

# GROQ_API_KEY=gsk-your-groq-key-here
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=your-groq-model-id

# FIREWORKS_API_KEY=fw-your-fireworks-key-here
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# FIREWORKS_MODEL=your-fireworks-model-id

# LOCAL_LLM_BASE_URL=http://localhost:8000/v1
# LOCAL_LLM_MODEL=your-local-model-id

# LLM_API_KEY=optional-custom-key
# LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
# LLM_MODEL=your-custom-model-id
